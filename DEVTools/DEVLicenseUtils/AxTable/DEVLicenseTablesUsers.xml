				<Source><![CDATA[
    public static DEVLicenseTablesUsers find(Name     _tableName,
                                             UserId   _userId,
                                             boolean  _forUpdate = false)
    {
        DEVLicenseTablesUsers licenseTablesUsers;
        ;
        licenseTablesUsers.selectForUpdate(_forUpdate);
        
        select firstonly licenseTablesUsers
            where licenseTablesUsers.TableName  == _tableName &&
                  licenseTablesUsers.UserId     == _userId;
        
        return licenseTablesUsers;
    }

]]></Source>
			</Method>
			<Method>
				<Name>exists</Name>
				<Source><![CDATA[
    public static boolean exists(Name     _tableName,
                                 UserId   _userId)
    {
        boolean res;
        ;
        res = (select firstonly RecId from DEVLicenseTablesUsers
                where DEVLicenseTablesUsers.TableName  == _tableName &&
                      DEVLicenseTablesUsers.UserId     == _userId).RecId != 0;
        
        return res;
    }

]]></Source>
