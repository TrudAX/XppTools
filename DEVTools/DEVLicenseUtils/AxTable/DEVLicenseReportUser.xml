			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    public static DEVLicenseReportUser find(UserId   _userId,
                                            boolean  _forUpdate = false)
    {
        DEVLicenseReportUser licenseReportUser;
        ;
        if (_userId)
        {
            licenseReportUser.selectForUpdate(_forUpdate);
            
            select firstonly licenseReportUser
                where licenseReportUser.UserId  == _userId;
        }
        
        return licenseReportUser;
    }

]]></Source>
			</Method>
			<Method>
				<Name>update</Name>
				<Source><![CDATA[
    public void update()
    {
        DEVLicenseReportUserComments		reportUserComments;
        if (this.Comment != this.orig().Comment)
        {
            ttsbegin;
            reportUserComments = DEVLicenseReportUserComments::find(this.UserId, true);
            reportUserComments.UserId  = this.UserId;
            reportUserComments.Comment = this.Comment;
            reportUserComments.write();
            ttscommit;
		}
        super();
    }

]]></Source>
